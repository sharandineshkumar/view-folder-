@model Complaint

@{
    ViewData["Title"] = "Submit Complaint";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card mt-3">
            <div class="card-header">
                Submit a New Complaint
            </div>
            <div class="card-body p-4">

                <form method="post" asp-controller="Complaints" asp-action="Create">

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" style="font-size:13px;"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Complaint Title</label>
                        <input asp-for="Title" class="form-control" placeholder="Enter a brief title for your complaint" />
                        <span asp-validation-for="Title" class="text-danger" style="font-size:12px;"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="5" placeholder="Describe your complaint in detail"></textarea>
                        <span asp-validation-for="Description" class="text-danger" style="font-size:12px;"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Category" class="form-label">Category</label>
                        <select asp-for="Category" class="form-select">
                            <option value="">-- Select Category --</option>
                            <option value="Roads">Roads</option>
                            <option value="Water">Water</option>
                            <option value="Electricity">Electricity</option>
                            <option value="Sanitation">Sanitation</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Category" class="text-bg-danger" style="font-size:15px;"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SubmittedBy" class="form-label">Your Name</label>
                        <input asp-for="SubmittedBy" class="form-control" placeholder="Enter your full name" />
                        <span asp-validation-for="SubmittedBy" class="text-bg-danger" style="font-size:15px;"></span>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary px-4">
                            Submit Complaint
                        </button>
                        <a asp-controller="Complaints" asp-action="Index" class="btn btn-outline-secondary px-4">
                            Cancel
                        </a>
                    </div>

                </form>

            </div>
        </div>

        <div class="mt-3 p-3" style="background:#fff8e1; border:1px solid #ffe082; border-radius:4px; font-size:12px; color:#5a4a00;">
            <strong>Note:</strong> Please ensure all details are accurate before submitting. False complaints may lead to action under applicable laws.
        </div>

    </div>
</div>