@model MVC_Project.Models.User

@{ 
    ViewData["Title"] = "Register ";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card mt-5">
            <div class="card-header">
                Create Citizen Account
            </div>
            <div class="card-body p-4">

                <form method="post" asp-controller="Account" asp-action="Register">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" style="font-size:13px;"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label">Full Name</label>
                        <input asp-for="FullName" class="form-control" placeholder="Enter your full name" />
                        <span asp-validation-for="FullName" class="text-danger" style="font-size:12px;"></span>
                        @*if user fills the form without filling the fullname *@
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email Address</label>
                        <input asp-for="Email" class="form-control" placeholder="Enter your email address" />
                        <span asp-validation-for="Email" class="text-danger" style="font-size:12px;"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" name="password" class="form-control" placeholder="Create a password" />
                        
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mt-2">
                        Create Account
                    </button>
                </form>

                <div class="mt-3 text-center" style="font-size:13px;">
                    <a asp-controller="Account" asp-action="Login" style="color:#003580;">
                        Already have an account? Login here
                    </a>
                </div>

            </div>
        </div>

        <div class="text-center mt-3" style="font-size:12px; color:#6b7280;">
            For official use only. Unauthorized access is prohibited.
        </div>
    </div>
</div>