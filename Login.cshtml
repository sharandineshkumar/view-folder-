@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card mt-5">
            <div class="card-header">
                Login to Your Account
            </div>
            <div class="card-body p-4">

                <form method="post" asp-controller="Account" asp-action="Login">

                    <div class="mb-3">
                        <label class="form-label">Email Address</label>
                        <input type="email" name="email" class="form-control" placeholder="Enter your registered email" />
                        <span class="text-danger" style="font-size:12px;">
                            @Html.ValidationMessage("email")
                        </span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" name="password" class="form-control" placeholder="Enter your password" />
                        <span class="text-danger" style="font-size:12px;">
                            @Html.ValidationMessage("password")
                        </span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mt-2">
                        Login
                    </button>

                </form>

                <div class="mt-3 text-center" style="font-size:13px;">
                    <a asp-controller="Account" asp-action="Register" style="color:#003580;">
                        Don't have an account? Register here
                    </a>
                </div>

            </div>
        </div>

        <div class="text-center mt-3" style="font-size:12px; color:#6b7280;">
            For official use only. Unauthorized access is prohibited.
        </div>
    </div>
</div>
